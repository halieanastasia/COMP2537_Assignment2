<% users.forEach( user => { %>
  <div class="card mb-3">
    <div class="card-body d-flex align-items-center justify-content-between">
        <div>
            <h6 class="mb-0"><%= user.username %></h6>
            <small class="text-muted"><%= user.email %></small>
            <span class="badge <%= (user.user_type==="admin") ? 'bg-success' : 'bg-secondary' %> ms-2">
                <%= (user.user_type==="admin") ? 'Admin' : 'User' %>
            </span>
        </div>
        <div class="d-flex gap-2">
            <form action="/promote" method="post">
                <input type="hidden" name="email" value="<%= user.email %>">
                <button class="btn btn-success btn-sm">Promote</button>
            </form>
            <form action="/demote" method="post">
                <input type="hidden" name="email" value="<%= user.email %>">
                <button class="btn btn-primary btn-sm">Demote</button>
            </form>
        </div>
    </div>
  </div>
<% }) %>